<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Фон -->
    <Color x:Key="BackgroundPrimary">#0D0D0D</Color>
    <Color x:Key="BackgroundSecondary">#1A1A1A</Color>
    <Color x:Key="BackgroundTertiary">#222222</Color>

    <!-- Текст -->
    <Color x:Key="TextPrimary">#FFFFFF</Color>
    <Color x:Key="TextSecondary">#AAAAAA</Color>
    <Color x:Key="TextMuted">#666666</Color>

    <!-- Акцент -->
    <Color x:Key="AccentPrimary">#00FFAA</Color>
    <Color x:Key="AccentSecondary">#00CC88</Color>

    <!-- Опасность / предупреждение -->
    <Color x:Key="DangerPrimary">#FF4444</Color>
    <Color x:Key="WarningPrimary">#FFAA00</Color>

    <!-- Сообщения -->
    <Color x:Key="BubbleMine">#1A3A2A</Color>
    <Color x:Key="BubbleOther">#1A1A2A</Color>

    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{StaticResource BackgroundPrimary}" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style TargetType="Entry">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}" />
        <Setter Property="BackgroundColor" Value="{StaticResource BackgroundSecondary}" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource AccentPrimary}" />
        <Setter Property="TextColor" Value="{StaticResource BackgroundPrimary}" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

</ResourceDictionary>