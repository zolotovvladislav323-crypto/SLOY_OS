<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:visualizers="clr-namespace:SLOY.UI.Forensics.Visualizers"
             x:Class="SLOY.App.Unified.Views.Mobile.DiagnosticsPage"
             BackgroundColor="#0D0D0D"
             Title="Диагностика">

    <Grid RowDefinitions="*, *" Padding="12" RowSpacing="12">

        <Frame Grid.Row="0" BackgroundColor="#1A1A1A" CornerRadius="8" Padding="8" HasShadow="False">
            <Grid RowDefinitions="Auto, *">
                <Label Grid.Row="0" Text="Спектр сигнала" FontSize="14" TextColor="#00FFAA" Margin="0,0,0,8" />
                <visualizers:SpectrumGraph Grid.Row="1" HeightRequest="200" />
            </Grid>
        </Frame>

        <Frame Grid.Row="1" BackgroundColor="#1A1A1A" CornerRadius="8" Padding="8" HasShadow="False">
            <Grid RowDefinitions="Auto, *">
                <Label Grid.Row="0" Text="Топология сети" FontSize="14" TextColor="#00FFAA" Margin="0,0,0,8" />
                <visualizers:TopologyGraph3D Grid.Row="1" HeightRequest="200" />
            </Grid>
        </Frame>

    </Grid>
</ContentPage>