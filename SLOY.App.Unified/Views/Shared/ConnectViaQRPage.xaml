<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SLOY.App.Unified.Views.Shared.ConnectViaQRPage"
             BackgroundColor="#0D0D0D"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *, Auto" Padding="20">

        <Label Grid.Row="0" Text="Подключение по QR"
               FontSize="22" FontAttributes="Bold"
               TextColor="#FFFFFF" HorizontalOptions="Center" Margin="0,20,0,20" />

        <Grid Grid.Row="1" VerticalOptions="Center" HorizontalOptions="Center">
            <Frame BackgroundColor="#FFFFFF" Padding="16" CornerRadius="12" HasShadow="False"
                   WidthRequest="260" HeightRequest="260">
                <Image x:Name="QRImage" Aspect="AspectFit" />
            </Frame>
        </Grid>

        <VerticalStackLayout Grid.Row="2" Spacing="12" Margin="0,0,0,20">
            <Button x:Name="RegenerateButton" Text="Сгенерировать новый код"
                    BackgroundColor="#333333" TextColor="#00FFAA"
                    CornerRadius="8" Clicked="OnRegenerateClicked" />
            <Button x:Name="ScanButton" Text="Сканировать код"
                    BackgroundColor="#00FFAA" TextColor="#0D0D0D"
                    CornerRadius="8" Clicked="OnScanClicked" />
        </VerticalStackLayout>

    </Grid>
</ContentPage>